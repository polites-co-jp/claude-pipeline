# claude-pipeline 環境変数
# コピーして .env として使用してください
# cp .env.example .env

# Anthropic API Key（Claude Code CLI で使用）
ANTHROPIC_API_KEY=

# GitHub Personal Access Token（repo, issues 権限が必要）
GITHUB_TOKEN=

# Discord Webhook URL（通知用）
DISCORD_WEBHOOK_URL=

# Claude Code モデル設定
# デフォルトモデル（全ステップ共通）
CLAUDE_MODEL=claude-sonnet-4-6
# ステップごとのモデル（設定するとデフォルトより優先される）
# CLAUDE_MODEL_IMPLEMENT=claude-sonnet-4-6
# CLAUDE_MODEL_REVIEW=claude-opus-4-6
# CLAUDE_MODEL_TEST=claude-sonnet-4-6
# CLAUDE_MODEL_DOCS=claude-haiku-4-5
